generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Client {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  cpfCnpj   String?
  segment   String
  address   String?
  notes     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  schedules Schedule[]
  payments  Payment[]
  locutions Locution[]
  nfes      NFe[]
}

model Locution {
  id        String   @id @default(cuid())
  title     String
  text      String?
  voice     String?
  type      String   @default("tts")
  duration  Int?
  fileUrl   String?
  musicStyle String?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}

model Schedule {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  locutionId String?
  date       String
  time       String?
  duration   String?
  local      String?
  value      Float    @default(0)
  status     String   @default("agendado")
  notes      String?
  createdAt  DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  description String?
  value       Float
  date        String
  dueDate     String?
  method      String   @default("pix")
  status      String   @default("recebido")
  createdAt   DateTime @default(now())
}

model NFe {
  id           String   @id @default(cuid())
  numero       String
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  emitente     String
  cnpj         String?
  destinatario String
  items        String
  subtotal     Float
  iss          Float
  total        Float
  formaPgto    String
  natureza     String?
  chaveAcesso  String
  dataEmissao  String
  obs          String?
  createdAt    DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  text      String
  type      String   @default("info")
  createdAt DateTime @default(now())
}
